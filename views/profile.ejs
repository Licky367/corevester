<%- include('partials/authLayout', {
  title: 'Profile',
  body: `
    <div class="container">

      <!-- FLASH MESSAGES -->
      ${success && success.length > 0 ? `<p style="color:green;">${success}</p>` : ''}
      ${error && error.length > 0 ? `<p style="color:red;">${error}</p>` : ''}

      <!-- PROFILE IMAGE -->
      <div class="profile-img">
        <img src="${user.profileImage || '/default.png'}" />
      </div>

      <!-- EDIT FORM -->
      <form action="/profile/update" method="POST" enctype="multipart/form-data">

        <label>Name</label>
        <input type="text" name="name" value="${user.name}" required />

        <label>Email</label>
        <input type="email" name="email" value="${user.email}" required />

        <label>Phone</label>
        <input type="text" name="phone" value="${user.phone}" required />

        <label>Profile Image</label>
        <input type="file" name="profileImage" />

        <button type="submit">Update Profile</button>
      </form>

    </div>

    <style>
      .container {
        max-width: 600px;
        margin: 40px auto;
        background: #fff;
        padding: 20px;
        border-radius: 10px;
      }

      .profile-img {
        text-align: center;
      }

      .profile-img img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
      }

      form {
        margin-top: 20px;
      }

      input {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
      }

      button {
        width: 100%;
        padding: 10px;
        background: #1877f2;
        color: white;
        border: none;
        cursor: pointer;
      }
    </style>
  `
}) %>